<% 
  autopilot = ENV.fetch('AUTOPILOT', 'px4')
  headless = ENV.fetch('HEADLESS', 'true') == 'true'
  camera = ENV.fetch('CAMERA', 'true') == 'true'
  lidar = ENV.fetch('LIDAR', 'true') == 'true'
  odom = ENV.fetch('ODOM', 'none')

  sim_subnet = ENV.fetch('SIM_SUBNET', '10.42')
  air_subnet = ENV.fetch('AIR_SUBNET', '10.22')
  sim_id = ENV.fetch('SIM_ID', '100')
  ground_id = ENV.fetch('GROUND_ID', '101')

  drone_type = ENV.fetch('DRONE_TYPE', 'quad')
  drone_id = ENV.fetch('DRONE_ID', 1).to_i

  hitl = ENV.fetch('HITL', 'false') == 'true'
  gnd_container = ENV.fetch('GND_CONTAINER', 'true') == 'true'

  record_rosbag = ENV.fetch('RECORD_ROSBAG', 'false') == 'true'

  simulated_time = ENV.fetch('SIMULATED_TIME', 'false') == 'true'
  remote_video_streams = ENV.fetch('REMOTE_VIDEO_STREAMS', 'false') == 'true'

  gymnasium = ENV.fetch('GYMNASIUM', 'false') == 'true'

  # Load sensor information from the sensor_config.yaml file
  require 'yaml'
  sensor_config = YAML.load_file('/aas/aircraft_resources/sensor_config.yaml')
  hfov_deg = sensor_config['sensors']['camera_intrinsics']['horizontal_fov_deg'].to_f
  stereo_cam = sensor_config['sensors']['camera_intrinsics']['stereo'] == true

  stereo_cam = false unless simulated_time # Stereo camera is for simulation only
  camera_ids = stereo_cam ? [0, 1] : [0] # In simulation, these will be UDP ports 5600, 5601, etc.
%>

name: drone

windows:

  - ap_interface:
      layout: even-horizontal
      panes:
        - clear && echo "So nice to have you with us, this is the aircraft <%= drone_id %> container."
        <% if autopilot == 'px4' %>
        - ros2 run autopilot_interface px4_interface --ros-args -r __ns:=/Drone<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
        <% elsif autopilot == 'ardupilot' %>
        - ros2 run autopilot_interface ardupilot_interface --ros-args -r __ns:=/Drone<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
        <% end %>

  - offboard_stateshare_dtc:
      layout: even-horizontal
      panes:
        <% if autopilot == 'px4' %>
        - ros2 run offboard_control px4_offboard --ros-args -r __ns:=/Drone<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
        <% elsif autopilot == 'ardupilot' %>
        - ros2 run offboard_control ardupilot_guided --ros-args -r __ns:=/Drone<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
        <% end %>
        - ros2 run state_sharing state_sharing_node --ros-args -p autopilot:=<%= autopilot %> -p drone_id:=<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
        - ros2 run drone_traffic_client dtc_client <%= simulated_time ? '--ros-args -p use_sim_time:=true' : '' %>

  - perception:
      layout: even-horizontal
      panes:
        <% if camera %>
        <% camera_ids.each do |cam_id| %>
        - until ros2 run yolo_py yolo_py --camera-id <%= cam_id %> <% if odom != 'none' %>--ros2-frame-publisher<% end %> <%= headless ? '--headless' : '' %> <%= hitl ? '--hitl' : '' %> <%= remote_video_streams ? '--remote-video-streams' : '' %> <%= simulated_time ? "--ros-args -p use_sim_time:=true --hfov #{hfov_deg}" : '' %>; do sleep 2; done
        <% end %>
        <% end %>
        <% if lidar %>
        - ros2 launch kiss_icp odometry.launch.py topic:=/lidar_points <%= headless ? 'visualize:=false' : '' %>
        <% end %>

  <% if odom != 'none' %>
  - odom:
      layout: even-horizontal
      panes:
        <% case odom %>
        <% when 'openvins' %>
        - ros2 launch ov_msckf subscribe.launch.py
        <% when 'fastlio' %>
        - ros2 launch spark_fast_lio mapping_vbr_colosseo.launch.yaml
        - ros2 launch kiss_matcher_ros run_kiss_matcher_sam.launch.yaml
        <% when 'superodom' %>
        - ros2 launch super_odometry livox_mid360.launch.py
        <% when 'mimosa' %>
        - ros2 launch mimosa parrot_launch.py
        - ros2 launch rovio rovio_node.launch.py
        <% end %>
        - ros2 run imu_publisher imu_publisher --ros-args -p autopilot:=<%= autopilot %> -p drone_id:=<%= drone_id %> <%= simulated_time ? '-p use_sim_time:=true' : '' %>
  <% end %>

  <% if autopilot == 'px4' %>
  - uxrce_dds_and_zenoh:
      layout: even-horizontal
      panes:
        - MicroXRCEAgent udp4 -p 8888
  <% elsif autopilot == 'ardupilot' %>
  - mavros_and_zenoh:
      layout: even-horizontal
      panes:
        - >
          <% if simulated_time %>
          sudo sed -i '0,/ros__parameters:/s/ros__parameters:/ros__parameters:\n    use_sim_time: true/' /opt/ros/humble/share/mavros/launch/apm_config.yaml && 
          ros2 launch mavros apm.launch fcu_url:=udp://<%= "#{sim_subnet}.90.#{drone_id}" %>:8888@8888 tgt_system:=<%= drone_id %>
          <% else %>
          ros2 launch mavros apm.launch fcu_url:=/dev/ttyTHS1:921600 tgt_system:=<%= drone_id %>
          <% end %>
  <% end %>
        - >
          erb /aas/aircraft_resources/comms/zenoh_config_air.json5.erb > /aas/aircraft_resources/comms/zenoh_config_air.json5 &&
          zenoh-bridge-ros2dds -e tcp/<%= gnd_container ? "#{air_subnet}.90.#{ground_id}" : "#{sim_subnet}.90.#{sim_id}" %>:7447 -c /aas/aircraft_resources/comms/zenoh_config_air.json5

  <% if lidar && !simulated_time %>
  - livox_driver:
      layout: tiled
      panes:
        - ros2 launch livox_ros_driver2 msg_MID360_launch.py
  <% end %>

  <% if record_rosbag %>
  - logging:
      layout: tiled
      panes:
        - mkdir -p /aas/rosbags && cd /aas/rosbags && ros2 bag record -a
  <% end %>

  <% if gymnasium %>
  - gymnasium:
      layout: even-horizontal
      panes:
        - python3 /aas/aircraft_resources/scripts/gymnasium_setup.py --drone_id <%= drone_id %> <%= simulated_time ? '--ros-args -p use_sim_time:=true' : '' %>
  <% end %>
